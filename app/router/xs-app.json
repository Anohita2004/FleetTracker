{
  "welcomeFile": "/comlocationtrackerlocationtracker/index.html",
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/do/logout",
    "logoutPage": "/comlocationtrackerlocationtracker/index.html",
    "logoutIdpPage": "https://accounts.sap.com/logout?redirect_uri=https%3A%2F%2F32e70d48trial-dev-locationtracker.cfapps.ap21.hana.ondemand.com%2Fcomlocationtrackerlocationtracker%2Findex.html"
  },
  "routes": [
    {
      "source": "^/login$",
      "target": "/comlocationtrackerlocationtracker/index.html",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/drivers/login$",
      "target": "/drivers/login",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/drivers/logout$",
      "target": "/drivers/logout",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/drivers/me$",
      "target": "/drivers/me",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/drivers/(.*)$",
      "target": "/drivers/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/?tracker/(.*)$",
      "target": "/tracker/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/?odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "none"
    }
  ]
}
