<mvc:View
  controllerName="com.locationtracker.locationtracker.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form"
  xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  displayBlock="true">
  <App id="app">
    <pages>
      <Page showHeader="false">
        <content>
          <VBox class="trackerPage">
            <VBox visible="{= ${appState>/sCurrentView} === 'loading' }" class="stateShell">
              <VBox class="centerCard" alignItems="Center" justifyContent="Center">
                <BusyIndicator size="2rem" />
                <Text text="Checking authentication status..." class="sapUiSmallMarginTop" />
              </VBox>
            </VBox>

            <VBox visible="{= ${appState>/sCurrentView} === 'error401' }" class="stateShell">
              <VBox class="centerCard" alignItems="Center" justifyContent="Center">
                <Title text="Access Denied" level="H3" />
                <Text text="Your session is not authorized to access this application." class="sapUiSmallMarginTop" />
                <Button text="Go to Login" type="Emphasized" press=".onGoToLogin" class="sapUiSmallMarginTop" />
              </VBox>
            </VBox>

            <VBox visible="{= ${appState>/sCurrentView} === 'loginPage' }" class="stateShell">
              <VBox class="centerCard">
                <Title text="FleetTracker" level="H2" />
                <Text text="Choose how you want to sign in." class="sapUiTinyMarginBottom" />
                <IconTabBar
                  expandable="false"
                  selectedKey="{appState>/loginTab}"
                  select=".onLoginTabSelect">
                  <items>
                    <IconTabFilter text="Admin Login" key="admin" icon="sap-icon://manager">
                      <VBox class="sapUiSmallMarginTop" width="100%">
                        <Text text="Use your FleetAdmin credentials." />
                        <Button text="Login as Fleet Admin" type="Emphasized" press=".onAdminLoginPress" class="sapUiSmallMarginTop" />
                      </VBox>
                    </IconTabFilter>
                    <IconTabFilter text="Driver Login" key="driver" icon="sap-icon://employee">
                      <VBox class="sapUiSmallMarginTop" width="100%">
                        <Label text="Email" />
                        <Input value="{appState>/driverLogin/email}" type="Email" width="100%" />
                        <Label text="Password" class="sapUiSmallMarginTop" />
                        <Input value="{appState>/driverLogin/password}" type="Password" width="100%" />
                        <Button text="Login" type="Emphasized" press=".onDriverLoginPress" class="sapUiSmallMarginTop" />
                      </VBox>
                    </IconTabFilter>
                  </items>
                </IconTabBar>
                <Text text="{appState>/authError}" visible="{= !!${appState>/authError} }" class="sapUiSmallMarginTop" />
                <ObjectStatus title="System Status" text="Not authenticated" state="Information" class="sapUiSmallMarginTop" />
              </VBox>
            </VBox>

            <VBox visible="{= ${appState>/sCurrentView} === 'adminDashboard' }">
              <Toolbar class="headerBar">
                <Title text="FleetTracker" />
                <ToolbarSpacer />
                <Text text="{appState>/adminProfile/name}" />
                <Button text="Manage Fleet" icon="sap-icon://shipping-status" type="Emphasized" press=".onNavigateToFleetOverview" />
                <Button text="Logout" type="Transparent" press=".onLogoutPress" />
              </Toolbar>

              <VBox class="sectionCard">
                <HBox justifyContent="SpaceBetween" alignItems="Center">
                  <Title text="Pending Registrations" level="H3" />
                  <ObjectStatus text="{= ${appState>/pendingDriverCount} > 0 ? ${appState>/pendingDriverCount} + ' pending' : 'None'}" state="{= ${appState>/pendingDriverCount} > 0 ? 'Warning' : 'None'}" />
                </HBox>
                <Table items="{appState>/pendingDrivers}" class="sapUiSmallMarginTop" noDataText="No pending registrations">
                  <columns>
                    <Column><Text text="Name" /></Column>
                    <Column><Text text="Email" /></Column>
                    <Column><Text text="Phone" /></Column>
                    <Column><Text text="License #" /></Column>
                    <Column><Text text="License Expiry" /></Column>
                    <Column><Text text="Document" /></Column>
                    <Column><Text text="Actions" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <Text text="{appState>name}" />
                        <Text text="{appState>email}" />
                        <Text text="{appState>phone}" />
                        <Text text="{appState>licenseNumber}" />
                        <Text text="{path: 'appState>licenseExpiry', formatter: '.formatDate'}" />
                        <Button text="View" press=".onViewDriverDoc">
                          <customData>
                            <core:CustomData key="driverDocUrl" value="{appState>documentUrl}" />
                          </customData>
                        </Button>
                        <HBox>
                          <Button text="Approve" type="Emphasized" press=".onApproveDriver">
                            <customData>
                              <core:CustomData key="driverId" value="{appState>ID}" />
                            </customData>
                          </Button>
                          <Button text="Reject" type="Reject" press=".onOpenRejectDialog">
                            <customData>
                              <core:CustomData key="driverId" value="{appState>ID}" />
                            </customData>
                          </Button>
                        </HBox>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>

              <VBox class="sectionCard">
                <HBox justifyContent="SpaceBetween" alignItems="Center">
                  <Title text="Drivers" level="H3" />
                  <Text text="Manage the drivers in your fleet." />
                </HBox>
                <Table items="{appState>/drivers}" class="sapUiSmallMarginTop" inset="false" mode="SingleSelectMaster" selectionChange=".onSelectDriver">
                  <columns>
                    <Column><Text text="Name" /></Column>
                    <Column><Text text="Email" /></Column>
                    <Column><Text text="Vehicle ID" /></Column>
                    <Column hAlign="Center"><Text text="Status" /></Column>
                    <Column hAlign="Center"><Text text="Activity" /></Column>
                    <Column><Text text="License #" /></Column>
                    <Column hAlign="Center"><Text text="Reg. Status" /></Column>
                    <Column hAlign="Center"><Text text="Action" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <Text text="{appState>name}" />
                        <Text text="{appState>email}" />
                        <Text text="{appState>vehicleId}" />
                        <ObjectStatus
                          text="{= ${appState>isActive} ? 'Active' : 'Inactive' }"
                          state="{= ${appState>isActive} ? 'Success' : 'Warning' }" />
                        <ObjectStatus
                          text="{appState>activityStatus}"
                          state="{= ${appState>activityStatus} === 'On Trip' ? 'Success' : 'None' }" />
                        <Text text="{appState>licenseNumber}" />
                        <ObjectStatus
                          text="{appState>registrationStatus}"
                          state="{= ${appState>registrationStatus} === 'APPROVED' ? 'Success' : ${appState>registrationStatus} === 'PENDING' ? 'Warning' : 'Error' }" />
                        <HBox>
                          <Button icon="sap-icon://decline" type="Transparent" press=".onDeleteDriver"
                                  visible="{= ${appState>isActive} }" tooltip="Deactivate" />
                          <Button icon="sap-icon://activate" type="Transparent" press=".onReactivateDriver"
                                  visible="{= !${appState>isActive} }" tooltip="Reactivate" />
                          <Button icon="sap-icon://delete" type="Transparent" press=".onPermanentlyDeleteDriver"
                                  visible="{= !${appState>isActive} }" tooltip="Permanently Delete" />
                        </HBox>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>

            </VBox>

            <VBox visible="{= ${appState>/sCurrentView} === 'driverDashboard' }">
              <Toolbar class="headerBar">
                <Title text="FleetTracker" />
                <ToolbarSpacer />
                <Text text="{appState>/driverProfile/name}" />
                <Button text="Logout" type="Transparent" press=".onLogoutPress" />
              </Toolbar>

              <VBox class="heroSection">
                <HBox class="heroRow" wrap="Wrap" justifyContent="SpaceBetween" alignItems="Center">
                  <VBox class="heroText">
                    <Title text="Driver Control Center" level="H2" />
                    <Text text="Start, stop, and monitor your trip in real time." class="heroSubtitle" />
                  </VBox>
                  <HBox wrap="Wrap" class="buttonCluster">
                    <Button text="{= ${appState>/currentTrip/ID} ? 'Resume Tracking' : 'Start Trip' }" type="Emphasized" press=".onStartTracking" visible="{= !${appState>/tracking} }" />
                    <Button text="Stop Trip" type="Reject" press=".onStopTracking" visible="{appState>/tracking}" />
                    <Button text="Refresh Path" icon="sap-icon://refresh" press=".onRefreshPath" />
                  </HBox>
                </HBox>
                <HBox class="statusStrip" wrap="Wrap" alignItems="Center">
                  <ObjectStatus title="System Status" text="{appState>/statusText}" state="{= ${appState>/tracking} ? 'Success' : 'Information' }" />
                  <ObjectStatus title="Location Permission" text="{appState>/permissionText}" state="{= ${appState>/tracking} ? 'Success' : 'Warning' }" />
                </HBox>
              </VBox>
            </VBox>

            <VBox visible="{= ${appState>/sCurrentView} === 'adminDashboard' || ${appState>/sCurrentView} === 'driverDashboard' }">
              <HBox wrap="Wrap" class="cardRow kpiRow">
                <Panel headerText="Current Trip" class="metricCard kpiCard">
                  <content>
                    <VBox class="metricContent">
                      <HBox justifyContent="SpaceBetween" alignItems="Center">
                        <ObjectStatus title="Title" text="{= ${appState>/currentTrip/title} || 'No active trip'}" />
                        <core:Icon src="sap-icon://journey-change" class="kpiIcon" />
                      </HBox>
                      <ObjectStatus title="Status" text="{= ${appState>/currentTrip/status} || 'IDLE'}" state="{= ${appState>/currentTrip/status} === 'ACTIVE' ? 'Success' : 'Information' }" />
                      <ObjectStatus title="Started At" text="{= ${appState>/currentTrip/startedAt} || '-'}" />
                    </VBox>
                  </content>
                </Panel>

                <Panel headerText="Live Position" class="metricCard kpiCard">
                  <content>
                    <VBox class="metricContent">
                      <HBox justifyContent="SpaceBetween" alignItems="Center">
                        <Title text="Latest Coordinates" level="H5" />
                        <core:Icon src="sap-icon://map-3" class="kpiIcon" />
                      </HBox>
                      <ObjectStatus title="Latitude" text="{= ${appState>/lastPoint/latitude} || '-'}" />
                      <ObjectStatus title="Longitude" text="{= ${appState>/lastPoint/longitude} || '-'}" />
                      <ObjectStatus title="Accuracy (m)" text="{= ${appState>/lastPoint/accuracy} || '-'}" />
                    </VBox>
                  </content>
                </Panel>

                <Panel headerText="Captured Points" class="metricCard kpiCard">
                  <content>
                    <VBox class="metricContent">
                      <HBox justifyContent="SpaceBetween" alignItems="Center">
                        <Title text="Path Density" level="H5" />
                        <core:Icon src="sap-icon://line-chart" class="kpiIcon" />
                      </HBox>
                      <ObjectNumber number="{appState>/totalPoints}" unit="pts" />
                      <ProgressIndicator percentValue="{= ${appState>/totalPoints} > 500 ? 100 : ${appState>/totalPoints} / 5 }" displayValue="{= ${appState>/totalPoints} + ' points captured'}" state="Success" />
                    </VBox>
                  </content>
                </Panel>
              </HBox>

              <Panel headerText="Route Map" class="mapPanel">
                <content>
                  <VBox class="mapShell">
                    <core:HTML id="trackerMap" content="&lt;div class='trackerMap' style='width:100%;height:100%;min-height:28rem;'&gt;&lt;/div&gt;" class="trackerMap" />
                  </VBox>
                </content>
              </Panel>

              <Panel headerText="Performance Metrics" class="metricCard metricsPanel">
                <content>
                  <HBox wrap="Wrap" class="cardRow">
                    <VBox class="metricContent metricColumn">
                      <ObjectStatus title="Total Trips" text="{appState>/metrics/totalTrips}" />
                      <ObjectStatus title="Completed Trips" text="{appState>/metrics/completedTrips}" />
                      <ObjectStatus title="Completion Rate" text="{= ${appState>/metrics/completionRate} + '%'}" state="Success" />
                      <ObjectStatus title="Avg Points / Trip" text="{appState>/metrics/avgPointsPerTrip}" />
                      <ObjectStatus title="Avg GPS Accuracy (m)" text="{appState>/metrics/avgGpsAccuracy}" />
                    </VBox>
                    <VBox class="metricContent metricColumn">
                      <ObjectStatus title="Avg Session Duration (ms)" text="{appState>/metrics/avgSessionDurationMs}" />
                      <ObjectStatus title="Backend Ingest Success" text="{= ${appState>/metrics/ingestSuccessRate} + '%'}" state="Success" />
                      <ObjectStatus title="Avg Backend Ingest Latency (ms)" text="{appState>/metrics/avgIngestLatencyMs}" />
                      <ObjectStatus title="Avg Client Update Latency (ms)" text="{appState>/metrics/avgClientUpdateLatencyMs}" />
                      <ObjectStatus title="Latest Client Update Latency (ms)" text="{appState>/metrics/latestClientUpdateLatencyMs}" />
                    </VBox>
                  </HBox>
                </content>
              </Panel>
            </VBox>
          </VBox>
        </content>
      </Page>

      <Page id="fleetOverviewPage" title="Fleet Management" showNavButton="true" navButtonPress=".onNavigateBackToDashboard">
        <content>
          <VBox class="trackerPage">
            <Toolbar>
              <Button text="Add Truck" icon="sap-icon://add" type="Emphasized" press=".onOpenAddTruckDialog" />
              <Button text="Refresh" icon="sap-icon://refresh" press=".onRefreshFleetOverview" />
              <ToolbarSpacer />
            </Toolbar>
            <HBox wrap="Wrap" class="cardRow kpiRow">
              <Panel headerText="Total Trucks" class="metricCard kpiCard">
                <content><ObjectNumber number="{appState>/fleetSummary/total}" unit="trucks" /></content>
              </Panel>
              <Panel headerText="Active" class="metricCard kpiCard">
                <content><ObjectNumber number="{appState>/fleetSummary/active}" /></content>
              </Panel>
              <Panel headerText="Idle" class="metricCard kpiCard">
                <content><ObjectNumber number="{appState>/fleetSummary/idle}" /></content>
              </Panel>
              <Panel headerText="Deactivated" class="metricCard kpiCard">
                <content><ObjectNumber number="{appState>/fleetSummary/deactivated}" /></content>
              </Panel>
            </HBox>
            <Table id="fleetTable" items="{appState>/trucks}" mode="SingleSelectMaster" selectionChange=".onSelectTruck">
              <columns>
                <Column><Text text="Truck #" /></Column>
                <Column><Text text="Model" /></Column>
                <Column><Text text="Registration" /></Column>
                <Column><Text text="Fuel Type" /></Column>
                <Column><Text text="Status" /></Column>
                <Column><Text text="Assigned Driver" /></Column>
                <Column hAlign="Center"><Text text="Actions" /></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{appState>truckNumber}" />
                    <Text text="{appState>model}" />
                    <Text text="{appState>registrationNumber}" />
                    <Text text="{appState>fuelType}" />
                    <ObjectStatus
                      text="{appState>status}"
                      state="{= ${appState>status} === 'ACTIVE' ? 'Success' : ${appState>status} === 'ON_TRIP' ? 'Warning' : ${appState>status} === 'IDLE' ? 'None' : 'Error' }" />
                    <Text text="{appState>assignedDriverName}" />
                    <HBox justifyContent="Center">
                      <Button icon="sap-icon://person-placeholder" tooltip="Assign Driver" press=".onOpenAssignDriverDialog">
                        <customData>
                          <core:CustomData key="truckId" value="{appState>ID}" />
                        </customData>
                      </Button>
                      <Button icon="sap-icon://detail-view" tooltip="View Details" press=".onNavigateToTruckDetail">
                        <customData>
                          <core:CustomData key="truckId" value="{appState>ID}" />
                        </customData>
                      </Button>
                      <Button icon="sap-icon://cancel" tooltip="Deactivate" press=".onDeactivateTruck" visible="{= ${appState>status} !== 'DEACTIVATED'}">
                        <customData>
                          <core:CustomData key="truckId" value="{appState>ID}" />
                        </customData>
                      </Button>
                    </HBox>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </VBox>
        </content>
      </Page>

      <Page id="truckDetailPage" title="Truck - {appState>/selectedTruck/truckNumber}" showNavButton="true" navButtonPress=".onNavigateBackToFleet">
        <content>
          <IconTabBar selectedKey="details" select=".onTruckDetailTabSelect">
            <items>
              <IconTabFilter key="details" text="Details">
                <VBox class="sapUiSmallMargin">
                  <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <Label text="Truck Number" />
                    <Input value="{appState>/selectedTruck/truckNumber}" />
                    <Label text="Model" />
                    <Input value="{appState>/selectedTruck/model}" />
                    <Label text="Registration" />
                    <Input value="{appState>/selectedTruck/registrationNumber}" />
                    <Label text="Fuel Type" />
                    <Select selectedKey="{appState>/selectedTruck/fuelType}">
                      <items>
                        <core:Item key="Petrol" text="Petrol" />
                        <core:Item key="Diesel" text="Diesel" />
                        <core:Item key="Electric" text="Electric" />
                        <core:Item key="CNG" text="CNG" />
                      </items>
                    </Select>
                    <Label text="Status" />
                    <Select selectedKey="{appState>/selectedTruck/status}">
                      <items>
                        <core:Item key="IDLE" text="IDLE" />
                        <core:Item key="ACTIVE" text="ACTIVE" />
                        <core:Item key="ON_TRIP" text="ON_TRIP" />
                        <core:Item key="IN_MAINTENANCE" text="IN_MAINTENANCE" />
                        <core:Item key="DEACTIVATED" text="DEACTIVATED" />
                      </items>
                    </Select>
                    <Label text="Assigned Driver" />
                    <Text text="{appState>/selectedTruck/assignedDriverName}" />
                  </form:SimpleForm>
                  <Toolbar>
                    <Button text="Save Changes" type="Emphasized" press=".onSaveTruckDetails" />
                    <Button text="Assign Driver" press=".onOpenAssignDriverDialog">
                      <customData>
                        <core:CustomData key="truckId" value="{appState>/selectedTruckId}" />
                      </customData>
                    </Button>
                  </Toolbar>
                </VBox>
              </IconTabFilter>
              <IconTabFilter key="metrics" text="Vehicle Metrics">
                <VBox class="sapUiSmallMargin">
                  <Toolbar>
                    <DateRangePicker id="metricsDateRange" />
                    <Button text="Load" press=".onLoadTruckMetrics" />
                  </Toolbar>
                  <HBox wrap="Wrap" class="cardRow kpiRow">
                    <ObjectStatus title="Avg Fuel (L)" text="{appState>/truckMetricsSummary/avgFuelLitres}" />
                    <ObjectStatus title="Min Tyre (PSI)" text="{appState>/truckMetricsSummary/minTyrePressure}" />
                    <ObjectStatus title="Max Temp (C)" text="{appState>/truckMetricsSummary/maxEngineTemp}" />
                    <ObjectStatus title="Total Readings" text="{appState>/truckMetricsSummary/totalReadings}" />
                  </HBox>
                  <Table id="metricsTable" items="{appState>/truckMetrics}">
                    <columns>
                      <Column><Text text="Captured At" /></Column>
                      <Column><Text text="Fuel (L)" /></Column>
                      <Column><Text text="FL PSI" /></Column>
                      <Column><Text text="FR PSI" /></Column>
                      <Column><Text text="RL PSI" /></Column>
                      <Column><Text text="RR PSI" /></Column>
                      <Column><Text text="Temp C" /></Column>
                      <Column><Text text="Odometer km" /></Column>
                      <Column><Text text="Source" /></Column>
                    </columns>
                    <items>
                      <ColumnListItem>
                        <cells>
                          <Text text="{path: 'appState>capturedAt', formatter: '.formatDateTime'}" />
                          <Text text="{appState>fuelLitres}" />
                          <Text text="{appState>tyreFL}" />
                          <Text text="{appState>tyreFR}" />
                          <Text text="{appState>tyreRL}" />
                          <Text text="{appState>tyreRR}" />
                          <Text text="{appState>engineTempC}" />
                          <Text text="{appState>odometerKm}" />
                          <Text text="{appState>source}" />
                        </cells>
                      </ColumnListItem>
                    </items>
                  </Table>
                </VBox>
              </IconTabFilter>
              <IconTabFilter key="thresholds" text="Alert Thresholds">
                <VBox class="sapUiSmallMargin">
                  <Text text="Thresholds are evaluated every 5 minutes against the latest vehicle metric reading." />
                  <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <Title text="Fuel Level (%)" />
                    <Label text="Warning below" />
                    <StepInput value="{appState>/thresholds/FUEL_LEVEL/warningAt}" min="0" max="100" step="1" />
                    <Label text="Critical below" />
                    <StepInput value="{appState>/thresholds/FUEL_LEVEL/criticalAt}" min="0" max="100" step="1" />
                    <Title text="Tyre Pressure (PSI)" />
                    <Label text="Warning below" />
                    <StepInput value="{appState>/thresholds/TYRE_PRESSURE/warningAt}" min="0" max="120" step="1" />
                    <Label text="Critical below" />
                    <StepInput value="{appState>/thresholds/TYRE_PRESSURE/criticalAt}" min="0" max="120" step="1" />
                    <Title text="Engine Temperature (C)" />
                    <Label text="Warning above" />
                    <StepInput value="{appState>/thresholds/ENGINE_TEMP/warningAt}" min="0" max="150" step="1" />
                    <Label text="Critical above" />
                    <StepInput value="{appState>/thresholds/ENGINE_TEMP/criticalAt}" min="0" max="150" step="1" />
                  </form:SimpleForm>
                  <Toolbar>
                    <Button text="Save Thresholds" type="Emphasized" press=".onSaveThresholds" />
                  </Toolbar>
                </VBox>
              </IconTabFilter>
              <IconTabFilter key="freightHistory" text="Freight History">
                <Table id="truckFreightTable" items="{appState>/truckFreightHistory}">
                  <columns>
                    <Column><Text text="Order #" /></Column>
                    <Column><Text text="Origin" /></Column>
                    <Column><Text text="Destination" /></Column>
                    <Column><Text text="Planned Departure" /></Column>
                    <Column><Text text="Status" /></Column>
                    <Column><Text text="Checkpoints" /></Column>
                    <Column><Text text="Driver" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <Text text="{appState>orderNumber}" />
                        <Text text="{appState>origin}" />
                        <Text text="{appState>destination}" />
                        <Text text="{path: 'appState>plannedDeparture', formatter: '.formatDateTime'}" />
                        <ObjectStatus
                          text="{appState>status}"
                          state="{= ${appState>status} === 'ACTIVE' ? 'Success' : ${appState>status} === 'ON_TRIP' ? 'Warning' : ${appState>status} === 'IDLE' ? 'None' : 'Error' }" />
                        <Text text="{appState>checkpointCount}" />
                        <Text text="{appState>driverName}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </IconTabFilter>
            </items>
          </IconTabBar>
        </content>
      </Page>
    </pages>
  </App>
</mvc:View>

