<mvc:View
  controllerName="com.locationtracker.locationtracker.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form"
  xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  displayBlock="true">
  <Page id="truckDetailPage" title="Truck - {appState>/selectedTruck/truckNumber}" showNavButton="true" navButtonPress=".onNavigateBackToFleet">
    <content>
      <IconTabBar selectedKey="details" select=".onTruckDetailTabSelect">
        <items>
          <IconTabFilter key="details" text="Details">
            <VBox class="sapUiSmallMargin">
              <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
                <Label text="Truck Number" />
                <Input value="{appState>/selectedTruck/truckNumber}" />
                <Label text="Model" />
                <Input value="{appState>/selectedTruck/model}" />
                <Label text="Registration" />
                <Input value="{appState>/selectedTruck/registrationNumber}" />
                <Label text="Fuel Type" />
                <Select selectedKey="{appState>/selectedTruck/fuelType}">
                  <items>
                    <core:Item key="Petrol" text="Petrol" />
                    <core:Item key="Diesel" text="Diesel" />
                    <core:Item key="Electric" text="Electric" />
                    <core:Item key="CNG" text="CNG" />
                  </items>
                </Select>
                <Label text="Status" />
                <Select selectedKey="{appState>/selectedTruck/status}">
                  <items>
                    <core:Item key="IDLE" text="IDLE" />
                    <core:Item key="ACTIVE" text="ACTIVE" />
                    <core:Item key="ON_TRIP" text="ON_TRIP" />
                    <core:Item key="IN_MAINTENANCE" text="IN_MAINTENANCE" />
                    <core:Item key="DEACTIVATED" text="DEACTIVATED" />
                  </items>
                </Select>
                <Label text="Assigned Driver" />
                <Text text="{appState>/selectedTruck/assignedDriverName}" />
              </form:SimpleForm>
              <Toolbar>
                <Button text="Save Changes" type="Emphasized" press=".onSaveTruckDetails" />
                <Button text="Assign Driver" press=".onOpenAssignDriverDialog">
                  <customData>
                    <core:CustomData key="truckId" value="{appState>/selectedTruckId}" />
                  </customData>
                </Button>
              </Toolbar>
            </VBox>
          </IconTabFilter>
          <IconTabFilter key="metrics" text="Vehicle Metrics">
            <VBox class="sapUiSmallMargin">
              <Toolbar>
                <DateRangeSelection id="metricsDateRange" />
                <Button text="Load" press=".onLoadTruckMetrics" />
              </Toolbar>
              <HBox wrap="Wrap" class="cardRow kpiRow">
                <ObjectStatus title="Avg Fuel (L)" text="{appState>/truckMetricsSummary/avgFuelLitres}" />
                <ObjectStatus title="Min Tyre (PSI)" text="{appState>/truckMetricsSummary/minTyrePressure}" />
                <ObjectStatus title="Max Temp (C)" text="{appState>/truckMetricsSummary/maxEngineTemp}" />
                <ObjectStatus title="Total Readings" text="{appState>/truckMetricsSummary/totalReadings}" />
              </HBox>
              <Table id="metricsTable" items="{appState>/truckMetrics}">
                <columns>
                  <Column><Text text="Captured At" /></Column>
                  <Column><Text text="Fuel (L)" /></Column>
                  <Column><Text text="FL PSI" /></Column>
                  <Column><Text text="FR PSI" /></Column>
                  <Column><Text text="RL PSI" /></Column>
                  <Column><Text text="RR PSI" /></Column>
                  <Column><Text text="Temp C" /></Column>
                  <Column><Text text="Odometer km" /></Column>
                  <Column><Text text="Source" /></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{path: 'appState>capturedAt', formatter: '.formatDateTime'}" />
                      <Text text="{appState>fuelLitres}" />
                      <Text text="{appState>tyreFL}" />
                      <Text text="{appState>tyreFR}" />
                      <Text text="{appState>tyreRL}" />
                      <Text text="{appState>tyreRR}" />
                      <Text text="{appState>engineTempC}" />
                      <Text text="{appState>odometerKm}" />
                      <Text text="{appState>source}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </VBox>
          </IconTabFilter>
          <IconTabFilter key="thresholds" text="Alert Thresholds">
            <VBox class="sapUiSmallMargin">
              <Text text="Thresholds are evaluated every 5 minutes against the latest vehicle metric reading." />
              <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
                <Title text="Fuel Level (%)" />
                <Label text="Warning below" />
                <StepInput value="{appState>/thresholds/FUEL_LEVEL/warningAt}" min="0" max="100" step="1" />
                <Label text="Critical below" />
                <StepInput value="{appState>/thresholds/FUEL_LEVEL/criticalAt}" min="0" max="100" step="1" />
                <Title text="Tyre Pressure (PSI)" />
                <Label text="Warning below" />
                <StepInput value="{appState>/thresholds/TYRE_PRESSURE/warningAt}" min="0" max="120" step="1" />
                <Label text="Critical below" />
                <StepInput value="{appState>/thresholds/TYRE_PRESSURE/criticalAt}" min="0" max="120" step="1" />
                <Title text="Engine Temperature (C)" />
                <Label text="Warning above" />
                <StepInput value="{appState>/thresholds/ENGINE_TEMP/warningAt}" min="0" max="150" step="1" />
                <Label text="Critical above" />
                <StepInput value="{appState>/thresholds/ENGINE_TEMP/criticalAt}" min="0" max="150" step="1" />
              </form:SimpleForm>
              <Toolbar>
                <Button text="Save Thresholds" type="Emphasized" press=".onSaveThresholds" />
              </Toolbar>
            </VBox>
          </IconTabFilter>
          <IconTabFilter key="freightHistory" text="Freight History">
            <Table id="truckFreightTable" items="{appState>/truckFreightHistory}">
              <columns>
                <Column><Text text="Order #" /></Column>
                <Column><Text text="Origin" /></Column>
                <Column><Text text="Destination" /></Column>
                <Column><Text text="Planned Departure" /></Column>
                <Column><Text text="Status" /></Column>
                <Column><Text text="Checkpoints" /></Column>
                <Column><Text text="Driver" /></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{appState>orderNumber}" />
                    <Text text="{appState>origin}" />
                    <Text text="{appState>destination}" />
                    <Text text="{path: 'appState>plannedDeparture', formatter: '.formatDateTime'}" />
                    <ObjectStatus
                      text="{appState>status}"
                      state="{= ${appState>status} === 'ACTIVE' ? 'Success' : ${appState>status} === 'ON_TRIP' ? 'Warning' : ${appState>status} === 'IDLE' ? 'None' : 'Error' }" />
                    <Text text="{appState>checkpointCount}" />
                    <Text text="{appState>driverName}" />
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </IconTabFilter>
        </items>
      </IconTabBar>
    </content>
  </Page>
</mvc:View>
