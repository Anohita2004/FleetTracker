<mvc:View
  controllerName="com.locationtracker.locationtracker.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  displayBlock="true">
  <Page id="gatePassesPage" title="Gate Passes" showNavButton="true" navButtonPress=".onNavigateBackToDashboard">
    <subHeader>
      <OverflowToolbar>
        <Title text="Gate Pass Register" />
        <ToolbarSpacer />
        <Select
          id="gatePassTruckFilter"
          selectedKey="{appState>/gatePassFilter/truckId}"
          change=".onGatePassFilterChange"
          forceSelection="false"
          items="{appState>/trucks}">
          <items>
            <core:Item key="{appState>ID}" text="{appState>truckNumber}" />
          </items>
        </Select>
        <Select
          id="gatePassOrderFilter"
          selectedKey="{appState>/gatePassFilter/freightOrderId}"
          change=".onGatePassFilterChange"
          forceSelection="false"
          items="{appState>/freightOrders}">
          <items>
            <core:Item key="{appState>ID}" text="{appState>orderNumber}" />
          </items>
        </Select>
        <Button text="Clear Filters" press=".onClearGatePassFilters" />
        <Button text="+ Log Gate Pass" type="Emphasized" press=".onOpenGatePassDialog" />
        <Button icon="sap-icon://refresh" press=".onRefreshGatePasses" />
      </OverflowToolbar>
    </subHeader>
    <content>
      <VBox class="sectionCard">
        <HBox wrap="Wrap" class="cardRow kpiRow">
          <Panel headerText="Total Passes" class="metricCard kpiCard">
            <content><ObjectNumber number="{appState>/gatePassCounts/total}" /></content>
          </Panel>
          <Panel headerText="Trucks OUT" class="metricCard kpiCard">
            <content><ObjectNumber number="{appState>/gatePassCounts/out}" state="Warning" /></content>
          </Panel>
          <Panel headerText="Trucks IN" class="metricCard kpiCard">
            <content><ObjectNumber number="{appState>/gatePassCounts/in}" state="Success" /></content>
          </Panel>
          <Panel headerText="Pending" class="metricCard kpiCard" visible="{= ${appState>/gatePassCounts/pending} > 0 }">
            <content><ObjectNumber number="{appState>/gatePassCounts/pending}" state="Error" /></content>
          </Panel>
        </HBox>

        <Table
          id="gatePassesTable"
          items="{appState>/gatePasses}"
          noDataText="No gate pass records found"
          growing="true"
          growingThreshold="25">
          <columns>
            <Column><Text text="Freight Order" /></Column>
            <Column><Text text="Truck" /></Column>
            <Column><Text text="Driver" /></Column>
            <Column><Text text="Direction" /></Column>
            <Column><Text text="Gate Officer" /></Column>
            <Column><Text text="Passed At" /></Column>
            <Column><Text text="Remarks" /></Column>
            <Column><Text text="Status" /></Column>
          </columns>
          <items>
            <ColumnListItem>
              <cells>
                <Text text="{appState>orderNumber}" />
                <Text text="{appState>truckNumber}" />
                <Text text="{appState>driverName}" />
                <ObjectStatus
                  text="{appState>direction}"
                  state="{= ${appState>direction} === 'OUT' ? 'Warning' : 'Success'}"
                  icon="{= ${appState>direction} === 'OUT' ? 'sap-icon://arrow-right' : 'sap-icon://arrow-left'}" />
                <Text text="{appState>gateOfficer}" />
                <Text text="{path: 'appState>passedAt', formatter: '.formatDateTime'}" />
                <Text text="{appState>remarks}" />
                <ObjectStatus
                  text="{appState>status}"
                  state="{= ${appState>status} === 'APPROVED' ? 'Success' : ${appState>status} === 'PENDING' ? 'Warning' : 'Error'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </content>
  </Page>
</mvc:View>
