<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog title="Reject Driver" draggable="false">
    <content>
      <Text text="Please provide a reason for rejecting this driver registration." />
      <TextArea value="{appState>/rejectReason}" placeholder="Enter reason for rejection..." rows="4" width="100%" />
    </content>
    <beginButton>
      <Button text="Reject" type="Reject" press=".onConfirmRejectDriver" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onCancelRejectDriver" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>