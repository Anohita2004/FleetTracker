<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <Dialog
    id="assignDriverDialog"
    title="Assign Driver to Truck"
    contentWidth="420px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Select Approved Driver" labelFor="driverAssignSelect" />
        <Select
          id="driverAssignSelect"
          selectedKey="{appState>/assignDriver/selectedDriverId}"
          width="100%"
          items="{appState>/approvedDrivers}">
          <core:Item
            key="{appState>ID}"
            text="{= ${appState>name} + ' - ' + ${appState>phone}}" />
        </Select>
        <Text
          text="Currently assigned: {appState>/selectedTruck/assignedDriverName}"
          class="sapUiTinyMarginTop" />
      </VBox>
    </content>
    <beginButton>
      <Button
        text="Assign"
        type="Emphasized"
        press=".onConfirmAssignDriver" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onCancelAssignDriver" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>